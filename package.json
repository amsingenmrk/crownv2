{
  "name": "Glassbox",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/sync-mapbox-csp-worker.mjs",
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start -p 3001",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "capture:landing-screenshot": "node scripts/capture-landing-portfolio-screenshot.mjs",
    "generate:benchmark-boundaries": "node scripts/generate-benchmark-market-boundaries.mjs",
    "generate:benchmark-submarket-boundaries": "node scripts/generate-benchmark-submarket-boundaries.mjs",
    "generate:asset-percentiles": "node scripts/generate-asset-percentiles.mjs",
    "generate:benchmarks": "node scripts/generate-benchmarks.mjs",
    "generate:benchmarks:export-csv": "node scripts/generate-benchmarks.mjs --export-csv",
    "generate:benchmark-data": "node scripts/generate-benchmarks.mjs && node scripts/generate-asset-percentiles.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/inter": "^5.2.8",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "highcharts": "^12.6.0",
    "highcharts-react-official": "^3.2.3",
    "lucide-react": "^0.577.0",
    "mapbox-gl": "^3.23.1",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-map-gl": "^8.1.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.3.0",
    "@turf/flatten": "^7.3.5",
    "@turf/helpers": "^7.3.5",
    "@turf/union": "^7.3.5",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.4",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}

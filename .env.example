# Mapbox GL JS (browser). https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: custom basemap (Mapbox Studio style URL or preset, e.g. mapbox://styles/mapbox/streets-v12).
# If unset, light/dark follows the app theme (light-v11 / dark-v11).
NEXT_PUBLIC_MAPBOX_STYLE_URL=

# Optional: server-only token for Geocoding API (recommended in production).
# If unset, NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN is used for geocoding on the server.
MAPBOX_ACCESS_TOKEN=
